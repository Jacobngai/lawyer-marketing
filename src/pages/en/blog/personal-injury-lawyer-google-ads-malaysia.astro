            class="inline-block bg-orange-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-orange-700 transition"
          >
            Get Your Free Marketing Consultation
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
