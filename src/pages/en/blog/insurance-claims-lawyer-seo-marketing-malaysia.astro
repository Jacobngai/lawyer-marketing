          </p>
          <a
            href="https://resultmarketing.asia"
            target="_blank"
            class="inline-block bg-white text-orange-700 px-8 py-3 rounded-lg font-semibold hover:bg-orange-50 transition-colors"
          >
            Visit ResultMarketing.asia →
          </a>
        </div>
      </div>

      <footer class="mt-12 pt-8 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500">Published: <time datetime={publishDate}>April 5, 2026</time></p>
            <p class="text-sm text-gray-500">Category: Insurance Law Marketing</p>
          </div>
          <a href="/en/blog" class="text-blue-600 hover:underline">← Back to Blog</a>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>
